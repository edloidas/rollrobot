{
  "name": "rollrobot",
  "version": "3.0.0",
  "type": "module",
  "description": "Roll Robot is a telegram bot used for common \"roll the dice\" purposes.",
  "keywords": [
    "rollrobot",
    "telegram",
    "bot",
    "roll",
    "dice",
    "random"
  ],
  "homepage": "https://github.com/edloidas/rollrobot",
  "bugs": {
    "url": "https://github.com/edloidas/rollrobot/issues",
    "email": "edloidas@gmail.com"
  },
  "license": "MIT",
  "author": "Mikita Taukachou <edloidas@gmail.com> (http://edloidas.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/edloidas/rollrobot.git"
  },
  "scripts": {
    "start": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "validate": "bun run typecheck && bun run check && bun test"
  },
  "dependencies": {
    "grammy": "^1.35.0",
    "roll-parser": "^2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.3.0",
    "typescript": "^5.7.0"
  }
}
